# --- Anthropic API (для AI-екстракції оголошень) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Database (SQLite) ---
# За замовчуванням приклад: ConnectionStrings__Default=Data Source=/app/data/rental_radar.db
# Для локальної розробки appsettings.json уже має sensible default.
ConnectionStrings__Default=Data Source=/app/data/rental_radar.db;Cache=Shared;Foreign Keys=True

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_CHAT_ID=123456789

# --- Facebook (для парсингу — використовуй спеціально створений акаунт!) ---
FACEBOOK_EMAIL=throwaway@example.com
FACEBOOK_PASSWORD=changeme

# --- Scraper settings ---
SCRAPE_INTERVAL_MINUTES=15
SCRAPE_HEADLESS=true
LISTING_RETENTION_DAYS=30

# --- Observability ---
SEQ_URL=http://seq:5341
