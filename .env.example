# --- Anthropic API (Phase 5: AI-екстракція полів з постів) ---
# Anthropic.SDK читає цю змінну за замовчуванням.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: override model/limits через Anthropic__Model, Anthropic__MaxTokens

# --- Database (SQLite) ---
# За замовчуванням приклад: ConnectionStrings__Default=Data Source=/app/data/rental_radar.db
# Для локальної розробки appsettings.json уже має sensible default.
ConnectionStrings__Default=Data Source=/app/data/rental_radar.db;Cache=Shared;Foreign Keys=True

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_CHAT_ID=123456789

# --- Facebook ---
# Session-based auth (Phase 4): один раз залогінитись через `tools/FbLogin`,
# отриманий storageState.json кластимо сюди. НЕ зберігаємо email/password.
# Рекомендований акаунт: окремий "tier-2", не основний (бан-ризик).
FACEBOOK_SESSION_PATH=/app/data/fb-session.json

# --- Scraper settings ---
SCRAPE_INTERVAL_MINUTES=15
SCRAPE_HEADLESS=true
LISTING_RETENTION_DAYS=30

# --- Observability ---
SEQ_URL=http://seq:5341
